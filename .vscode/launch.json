{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Cucaracha",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "make build"
        },
        {
            "name": "Launch Generate LLVM TableGen",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "cwd": "${workspaceFolder}",
            "args": [
                "tools",
                "generateLlvmTableGen"
            ],
            "preLaunchTask": "make build"
        },
        {
            "name": "Debug Debugger TUI",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "args": [
                "debug",
                "--tui",
                "programs/program.c"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "showLog": false,
            "logOutput": "rpc",
            "preLaunchTask": "make build"
        },
        {
            "name": "Debug Debugger REPL",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "args": [
                "debug",
                "programs/program.c",
                "--settings-file", "${workspaceFolder}/cmd/repl-settings.yaml"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "showLog": false,
            "logOutput": "rpc",
            "preLaunchTask": "make build"
        },
        {
            "name": "Debug Code Generator (ui/debugger)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/pkg/ui/debugger/generator.go",
            "args": [
                "-out", "commands.go",
                "-api", "api.go"
            ],
            "cwd": "${workspaceFolder}/pkg/ui/debugger",
            "console": "integratedTerminal",
            "showLog": false,
            "logOutput": "rpc",
            "preLaunchTask": "make build"
        }
    ]
}